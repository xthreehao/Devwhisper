QDRANT_URL=your_qdrant_cluster_url
QDRANT_API_KEY=your_qdrant_api_key

# Groq config (used when LLM_API_KEY is not set)
GROQ_API_KEY=your_groq_api_key

# OpenAI-compatible provider config (used when LLM_API_KEY is set)
# LLM_API_KEY=your-api-key
# LLM_BASE_URL=your-base-url
# LLM_MODEL=your-llm-model

# Admin secret for /admin/* debugging endpoints (e.g. /admin/sessions).
# If unset, admin endpoints fail closed (always 401). Generate a strong,
# random value for production (e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`).
ADMIN_SECRET=change-me-to-a-long-random-secret
